GATEWAY_ENV=production
GATEWAY_PORT=8080
GATEWAY_ADDR=:8080
GATEWAY_XIAOGUGIT_URL=http://host.docker.internal:8000
GATEWAY_PROBABILITY_URL=http://host.docker.internal:5000
GATEWAY_SERVICE_API_KEY=change-me
GATEWAY_XG_AUTH_SECRET=xiaogugit-auth-secret
